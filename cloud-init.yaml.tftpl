#cloud-config
package_update: true
packages:
  - nginx
runcmd:
  - curl -fsSL https://tailscale.com/install.sh | sh
  - tailscale up --authkey=${tailscale_auth_key} --hostname=contractor-demo-app
  - echo "<h1>Internal Contractor Portal</h1><p>If you can see this, ACL access works.</p>" > /var/www/html/index.html